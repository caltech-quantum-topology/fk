Cell[CellGroupData[{

Cell["\<\
Functions that deal with multicycles in a braid that do not go through the \
open strand and Alexander polynomial computations [not needed]\
\>", "Subsubsection",
 CellChangeTimes->{{3.982783431935286*^9, 3.982783474760188*^9}, {
  3.982784115427651*^9, 3.982784131909333*^9}, {3.982784171861971*^9, 
  3.9827841827988253`*^9}},ExpressionUUID->"e5eea385-9d58-45ad-8dce-\
7407620b554f"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{"In", " ", "this", " ", "section"}], ",", " ", 
   RowBox[{
   "we", " ", "do", " ", "not", " ", "\"\<close the open strand\>\""}], ",", 
   " ", 
   RowBox[{
   "as", " ", "is", " ", "required", " ", "for", " ", "computations", " ", 
    "of", " ", "the", " ", "Alexander", " ", "polynomial", " ", "using", " ", 
    "the", " ", "Bureau", " ", 
    RowBox[{"representation", ".", " ", "As"}], " ", "a", " ", "result"}], ",",
    " ", 
   RowBox[{
   "the", " ", "cycles", " ", "that", " ", "we", " ", "generate", " ", "do", " ",
     "not", " ", "go", " ", "through", " ", "the", " ", "open", " ", 
    "segment", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"bottom", " ", "left"}], "-", 
      RowBox[{"most", " ", "and", " ", "top", " ", "left"}], "-", 
      RowBox[{"most", " ", "strand"}]}], ")"}]}]}], "*)"}]], "Input",
 CellChangeTimes->{{3.9827837134061623`*^9, 
  3.9827837613167686`*^9}},ExpressionUUID->"7b4ef9f9-88b9-4e1f-99b0-\
0b0b959a2fb8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"alexMatrix", "[", "braid_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "Cs", ",", "n", ",", "A", ",", "s", ",", "i", ",", "j", ",", "k", ",", 
        "\[CapitalDelta]", ",", "G", ",", "\[Rho]1"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Returns", " ", "2", " ", 
         RowBox[{"things", ":", " ", 
          RowBox[{
          "first", " ", "the", " ", "matrix", " ", "that", " ", "computes", " ",
            "Alexander", " ", "by", " ", "taking", " ", "its", " ", 
           "determinant"}]}]}], ",", " ", 
        RowBox[{
        "and", " ", "second", " ", "the", " ", "exponent", " ", "of", " ", 
         "t", " ", "that", " ", "we", " ", "need", " ", "to", " ", "shift", " ",
          "by", " ", "to", " ", "recover", " ", "the", " ", "correct", " ", 
         "normalization", " ", "of", " ", "the", " ", "alexander"}]}], "*)"}],
       "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Cs", "=", 
        RowBox[{"NewRot", "[", "braid", "]"}]}], ";", "\[IndentingNewLine]", 
       " ", 
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "Cs", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"A", "=", 
        RowBox[{"IdentityMatrix", "[", 
         RowBox[{
          RowBox[{"2", "n"}], "+", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Cases", "[", 
        RowBox[{"Cs", ",", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"s_", ",", "i_", ",", "j_"}], "}"}], ":>", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"A", "\[LeftDoubleBracket]", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"i", ",", "j"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"i", "+", "1"}], ",", 
                RowBox[{"j", "+", "1"}]}], "}"}]}], "\[RightDoubleBracket]"}],
             "+=", 
            RowBox[{"(", GridBox[{
               {
                RowBox[{"-", 
                 SuperscriptBox["t", "s"]}], 
                RowBox[{
                 SuperscriptBox["t", "s"], "-", "1"}]},
               {"0", 
                RowBox[{"-", "1"}]}
              }], ")"}]}], ")"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"A", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"Total", "@", 
              RowBox[{"Sign", "[", "braid", "]"}]}]}], "+", 
            RowBox[{"Max", "[", 
             RowBox[{"Abs", "[", "braid", "]"}], "]"}]}], ")"}], "/", "2"}]}],
         "}"}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
  "\[IndentingNewLine]", 
