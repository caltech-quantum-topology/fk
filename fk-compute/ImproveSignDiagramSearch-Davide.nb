             RowBox[{"2", "n"}], "+", "1"}], ")"}]}]}], "}"}], " ", "where", " ",
         "r", " ", "is", " ", "the", " ", 
        RowBox[{"permutation", ":"}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"perms", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"Last", "/@", "#"}], ")"}], "&"}], "/@", "perms"}]}], ";", 
      "\[IndentingNewLine]", "perms"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"weightPermsClosed", "[", "braid_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"n", ",", "alex", ",", "perms"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "It", " ", "returns", " ", "a", " ", "vector", " ", "with", " ", "all", 
       " ", "possible", " ", "cycles", " ", 
       RowBox[{"(", 
        RowBox[{"in", " ", "permutation", " ", "list", " ", "form"}], ")"}], " ",
        "and", " ", "their", " ", "correspondent", " ", "weights", " ", "to", 
       " ", "compute", " ", "Alexander"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"n", "=", 
       RowBox[{"Length", "[", "braid", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"alex", "=", 
       RowBox[{"alexMatrixClosed", "[", "braid", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"perms", "=", 
       RowBox[{"permsRotClosed", "[", "braid", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"#", ",", 
          RowBox[{
           SuperscriptBox["t", 
            RowBox[{"alex", "[", 
             RowBox[{"[", "2", "]"}], "]"}]], 
           RowBox[{"Signature", "[", "#", "]"}], 
           RowBox[{"Product", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"alex", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "[", 
              RowBox[{"[", 
               RowBox[{"j", ",", 
                RowBox[{"#", "[", 
                 RowBox[{"[", "j", "]"}], "]"}]}], "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", 
               RowBox[{
                RowBox[{"2", "n"}], "+", "1"}]}], "}"}]}], "]"}]}]}], "}"}], 
        "&"}], "/@", "perms"}]}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]}], "Input",
