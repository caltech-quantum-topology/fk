Cell[CellGroupData[{

Cell["\<\
Functions that identify crossings and label segments in a braid\
\>", "Subsubsection",
 CellChangeTimes->{{3.9803603561176023`*^9, 3.980360597545371*^9}, {
   3.980362273237595*^9, 3.980362281315699*^9}, 3.980371183728882*^9, {
   3.98278337234365*^9, 
   3.982783398009004*^9}},ExpressionUUID->"b2af7515-e0b0-4814-b569-\
c82362b59e16"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"labelCrossings", "[", "braid_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "labelsCorners", ",", "jfirst", ",", "j", ",", "corner", ",", "k", ",", 
       "jnext", ",", 
       RowBox[{"first", "=", "True"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"In", " ", "this", " ", "function"}], ",", " ", 
       RowBox[{
       "we", " ", "label", " ", "the", " ", "crossings", " ", "by", " ", 
        "starting", " ", "with", " ", "1", " ", "in", " ", "the", " ", 
        "bottom", " ", "of", " ", "the", " ", "open", " ", 
        RowBox[{"(", 
         RowBox[{"left", "-", "most"}], ")"}], " ", "strand"}], ",", " ", 
       RowBox[{
       "and", " ", "changing", " ", "label", " ", "after", " ", "going", " ", 
        "through", " ", "each", " ", "crossing"}], ",", " ", 
       RowBox[{
       "independetly", " ", "of", " ", "whether", " ", "we", " ", "go", " ", 
        "through", " ", "the", " ", "understrand", " ", "or", " ", 
        RowBox[{"overstrand", ".", " ", "k"}], " ", "keeps", " ", "track", " ",
         "of", " ", "the", " ", "label", " ", 
        RowBox[{"(", "segment", ")"}]}], ",", " ", 
       RowBox[{
       "and", " ", "j", " ", "of", " ", "the", " ", "crossing", " ", 
        "position", " ", "in", " ", "the", " ", "braid"}]}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"labelsCorners", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{"0", ",", "4"}], "]"}], ",", 
         RowBox[{"Length", "[", "braid", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"k", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"jfirst", "=", 
       RowBox[{"firstAppearance", "[", 
        RowBox[{"braid", ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"j", "=", "jfirst"}], ";", "\[IndentingNewLine]", 
      RowBox[{"corner", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"labelsCorners", "[", 
        RowBox[{"[", 
         RowBox[{"j", ",", "corner"}], "]"}], "]"}], "=", "k"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"first", "||", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"j", "==", "jfirst"}], "&&", 
             RowBox[{"corner", "==", "1"}]}], ")"}]}], "&&", 
          RowBox[{"k", "<=", 
           RowBox[{
            RowBox[{"2", 
             RowBox[{"Length", "[", "braid", "]"}]}], "-", "1"}]}]}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"first", "=", "False"}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{
            RowBox[{"--", 
             RowBox[{"-", "Start"}]}], " ", "the", " ", 
            RowBox[{"procedure", "--"}]}], "-"}], "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{"k", "=", 
          RowBox[{"k", "+", "1"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"move", " ", "through", " ", "the", " ", 
           RowBox[{"crossing", ":", " ", 
            RowBox[{
            "next", " ", "corner", " ", "in", " ", "same", " ", 
             "crossing"}]}]}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{"corner", "=", 
          RowBox[{"Which", "[", 
           RowBox[{
            RowBox[{"corner", "==", "1"}], ",", "4", ",", 
            RowBox[{"corner", "==", "2"}], ",", "3", ",", "True", ",", 
            "corner"}], "   ", 
           RowBox[{"(*", 
            RowBox[{"safety", ":", 
             RowBox[{
              RowBox[{"keep", " ", "as"}], "-", 
              RowBox[{"is", " ", "if", " ", "corner", " ", "is", " ", 
               RowBox[{"3", "/", "4"}]}]}]}], "*)"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"labelsCorners", "[", 
           RowBox[{"[", 
            RowBox[{"j", ",", "corner"}], "]"}], "]"}], "=", "k"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"move", " ", "to", " ", "next", " ", 
           RowBox[{"crossing", ":"}]}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{
           "If", " ", "we", " ", "have", " ", "reached", " ", "the", " ", 
            "top", " ", "strand"}], ",", " ", 
           RowBox[{
           "depending", " ", "on", " ", "whether", " ", "we", " ", "are", " ",
             "in", " ", "corner", " ", "3", " ", "or", " ", "4"}], ",", " ", 
           RowBox[{
           "we", " ", "go", " ", "around", " ", "and", " ", "check", " ", 
            "whether", " ", 
            RowBox[{"braid", "[", 
             RowBox[{"[", "j", "]"}], "]"}], " ", "appears", " ", "first", " ",
             "than", " ", "its", " ", "left", " ", "or", " ", "right", " ", 
            "generator", " ", 
            RowBox[{"resp", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{"jnext", "=", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"topstrandQ", "[", 
             RowBox[{"braid", ",", "j", ",", "corner"}], "]"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"corner", "==", "3"}], ",", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Abs", "@", 
                  RowBox[{"braid", "[", 
                   RowBox[{"[", "j", "]"}], "]"}]}], ">", "1"}], ",", 
                RowBox[{"Min", "[", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"firstAppearance", "[", 
                    RowBox[{"braid", ",", 
                    RowBox[{"Abs", "@", 
                    RowBox[{"braid", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}]}], "]"}], ",", 
                   RowBox[{"firstAppearance", "[", 
                    RowBox[{"braid", ",", 
                    RowBox[{
                    RowBox[{"Abs", "@", 
                    RowBox[{"braid", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], "-", "1"}]}], "]"}]}], 
                  "}"}], "]"}], ",", 
                RowBox[{"firstAppearance", "[", 
                 RowBox[{"braid", ",", 
                  RowBox[{"Abs", "@", 
                   RowBox[{"braid", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}]}], "]"}]}], "]"}], ",", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"corner", "==", "4"}], ",", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"Abs", "@", 
                    RowBox[{"braid", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], "<", 
                   RowBox[{"Max", "@", 
                    RowBox[{"Abs", "@", "braid"}]}]}], ",", 
                  RowBox[{"Min", "[", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{"firstAppearance", "[", 
                    RowBox[{"braid", ",", 
                    RowBox[{"Abs", "@", 
                    RowBox[{"braid", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}]}], "]"}], ",", 
                    RowBox[{"firstAppearance", "[", 
                    RowBox[{"braid", ",", 
                    RowBox[{
                    RowBox[{"Abs", "@", 
                    RowBox[{"braid", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], "+", "1"}]}], "]"}]}], 
                    "}"}], "]"}], ",", 
                  RowBox[{"firstAppearance", "[", 
                   RowBox[{"braid", ",", 
                    RowBox[{"Abs", "@", 
                    RowBox[{"braid", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}]}], "]"}]}], "]"}]}], 
               "]"}]}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"Else", ",", " ", 
           RowBox[{
           "we", " ", "consider", " ", "the", " ", "next", " ", "appearance", 
            " ", "of", " ", "either", " ", "a", " ", "generator", " ", "to", " ",
             "the", " ", "right"}], ",", " ", 
           RowBox[{"left", " ", "or", " ", "same", " ", "type"}], ",", " ", 
           RowBox[{
           "depending", " ", "on", " ", "what", " ", "corner", " ", "we", " ",
             "are", " ", "in", " ", "and", " ", "what", " ", "type", " ", 
            "of", " ", 
            RowBox[{"generator", ":"}]}]}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{"jnext", "=", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"topstrandQ", "[", 
              RowBox[{"braid", ",", "j", ",", "corner"}], "]"}]}], ",", 
            RowBox[{"Min", "@", 
             RowBox[{"DeleteCases", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{"!", 
                    RowBox[{"lastAppearanceQ", "[", 
                    RowBox[{"braid", ",", "j"}], "]"}]}], ",", 
                   RowBox[{"nextgeneratorpos", "[", 
                    RowBox[{"braid", ",", 
                    RowBox[{"Abs", "@", 
                    RowBox[{"braid", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], ",", "j"}], "]"}], ",", 
                   "Nothing"}], "]"}], ",", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{
                    RowBox[{"Abs", "@", 
                    RowBox[{"braid", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], ">", "1"}], "&&", 
                    RowBox[{"corner", "==", "3"}]}], ",", 
                   RowBox[{"nextgeneratorpos", "[", 
                    RowBox[{"braid", ",", 
                    RowBox[{
                    RowBox[{"Abs", "@", 
                    RowBox[{"braid", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], "-", "1"}], ",", "j"}], 
                    "]"}], ",", "Nothing"}], "]"}], ",", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{
                    RowBox[{"Abs", "@", 
                    RowBox[{"braid", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], "<", 
                    RowBox[{"Max", "[", 
                    RowBox[{"Abs", "[", "braid", "]"}], "]"}]}], "&&", 
                    RowBox[{"corner", "==", "4"}]}], ",", 
                   RowBox[{"nextgeneratorpos", "[", 
                    RowBox[{"braid", ",", 
                    RowBox[{
                    RowBox[{"Abs", "@", 
                    RowBox[{"braid", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], "+", "1"}], ",", "j"}], 
                    "]"}], ",", "Nothing"}], "]"}]}], "}"}], ",", "Nothing"}],
               "]"}]}], ",", "jnext"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "We", " ", "change", " ", "corners", " ", "to", " ", "match", " ", 
           "the", " ", "new", " ", "crossing"}], "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{"corner", "=", 
          RowBox[{"Which", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Abs", "@", 
              RowBox[{"braid", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}], "==", 
             RowBox[{"Abs", "@", 
              RowBox[{"braid", "[", 
               RowBox[{"[", "jnext", "]"}], "]"}]}]}], ",", 
            RowBox[{"Which", "[", 
             RowBox[{
              RowBox[{"corner", "==", "3"}], ",", "1", ",", 
              RowBox[{"corner", "==", "4"}], ",", "2"}], "]"}], ",", 
            RowBox[{
             RowBox[{"Abs", "@", 
              RowBox[{"braid", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}], "!=", 
             RowBox[{"Abs", "@", 
              RowBox[{"braid", "[", 
               RowBox[{"[", "jnext", "]"}], "]"}]}]}], ",", 
            RowBox[{"Which", "[", 
             RowBox[{
              RowBox[{"corner", "==", "3"}], ",", "2", ",", 
              RowBox[{"corner", "==", "4"}], ",", "1"}], "]"}]}], "]"}]}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "We", " ", "update", " ", "the", " ", "crossing", " ", "we", " ", 
           "are", " ", "at"}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{"j", "=", "jnext"}], ";", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"labelsCorners", "[", 
           RowBox[{"[", 
            RowBox[{"j", ",", "corner"}], "]"}], "]"}], "=", "k"}], ";"}]}], 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
          RowBox[{"--", 
           RowBox[{"-", "End"}]}], " ", "the", " ", 
          RowBox[{"procedure", "--"}]}], "-"}], "*)"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "We", " ", "add", " ", "the", " ", "last", " ", "segment", " ", "that",
         " ", "we", " ", 
        RowBox[{"didn", "'"}], "t", " ", "go", " ", "through", " ", 
        RowBox[{"(", 
         RowBox[{
         "that", " ", "closes", " ", "to", " ", "the", " ", "open", " ", 
          "strand"}], ")"}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"labelsCorners", "[", 
            RowBox[{"[", 
             RowBox[{"n", ",", "m"}], "]"}], "]"}], "==", "0"}], ",", 
          RowBox[{
           RowBox[{"labelsCorners", "[", 
            RowBox[{"[", 
             RowBox[{"n", ",", "m"}], "]"}], "]"}], "=", 
           RowBox[{"k", "+", "1"}]}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "1", ",", 
          RowBox[{"Length", "[", "labelsCorners", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"m", ",", "1", ",", 
          RowBox[{"Length", "[", 
           RowBox[{"labelsCorners", "[", 
            RowBox[{"[", "n", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", "labelsCorners"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"NewRot", "[", "braid_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"labelsCorners", ",", "rotVec"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"labelsCorners", "=", 
       RowBox[{"labelCrossings", "[", "braid", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"For", " ", "each", " ", "crossing"}], ",", " ", 
        RowBox[{"we", " ", "keep", " ", "create", " ", "a", " ", "vector", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"sign", " ", "crossing"}], ",", " ", 
           RowBox[{"bottom", " ", "overstrand"}], ",", " ", 
           RowBox[{"bottom", " ", "understrand", " ", "label"}]}], "}"}]}], ",",
         " ", 
        RowBox[{
        "in", " ", "the", " ", "same", " ", "order", " ", "as", " ", "the", " ",
          "crossings", " ", "appear", " ", "in", " ", "braid"}]}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"rotVec", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Sign", "[", 
              RowBox[{"braid", "[", 
               RowBox[{"[", "n", "]"}], "]"}], "]"}], ",", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Sign", "[", 
                 RowBox[{"braid", "[", 
                  RowBox[{"[", "n", "]"}], "]"}], "]"}], "==", "1"}], ",", 
               RowBox[{"labelsCorners", "[", 
                RowBox[{"[", 
                 RowBox[{"n", ",", 
                  RowBox[{"{", 
                   RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}], ",", 
               RowBox[{"labelsCorners", "[", 
                RowBox[{"[", 
                 RowBox[{"n", ",", 
                  RowBox[{"{", 
                   RowBox[{"2", ",", "1"}], "}"}]}], "]"}], "]"}]}], "]"}]}], 
            "}"}], ",", "1"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", "1", ",", 
           RowBox[{"Length", "[", "braid", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "rotVec"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]}], "Input",
