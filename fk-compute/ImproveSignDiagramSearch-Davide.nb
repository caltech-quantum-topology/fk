Cell[CellGroupData[{

Cell["\<\
Function that takes a permutation and gives the corresponding sign diagram\
\>", "Subsubsection",
 CellChangeTimes->{{3.982783898968564*^9, 
  3.982783904876966*^9}},ExpressionUUID->"f92ec13f-9872-4828-93f7-\
0e66d9b786f7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "We", " ", "assume", " ", "that", " ", "the", " ", "enumeration", " ", 
     "of", " ", "the", " ", "labels", " ", "follows", " ", "the", " ", 
     "knot"}], ",", " ", 
    RowBox[{"as", " ", "in", " ", "our", " ", 
     RowBox[{"functions", ".", " ", "This"}], " ", "is", " ", "only", " ", 
     "for", " ", 
     RowBox[{"KNOTS", ".", " ", "It"}], " ", "would", " ", "have", " ", "to", 
     " ", "be", " ", "modified", " ", "for", " ", "LINKS"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"permToSigns", "[", "perm_", "]"}], ":=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"perm", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "==", "i"}], ",", "1", ",", 
       RowBox[{"-", "1"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{
        RowBox[{"Length", "[", "perm", "]"}], "-", "1"}]}], "}"}]}], 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.982783957027255*^9, 3.98278397107539*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"3d254fc2-9934-49dc-ab8b-75ee29e8576b"]
}, Closed]]
}, Open  ]],

