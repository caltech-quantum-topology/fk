Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"topstrandQ", "[", 
    RowBox[{"braid_", ",", "j_", ",", "corner_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "bool", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Given", " ", "a", " ", "braid"}], ",", " ", 
       RowBox[{
       "what", " ", "crossing", " ", "j", " ", "we", " ", "are", " ", "in", " ",
         "the", " ", "braid"}], ",", " ", 
       RowBox[{
       "and", " ", "what", " ", "corner", " ", "of", " ", "said", " ", 
        "crossing"}], ",", " ", 
       RowBox[{
       "it", " ", "returns", " ", "whether", " ", "we", " ", "are", " ", "at",
         " ", "the", " ", "top", " ", "strand"}]}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"corner", " ", "is", " ", "labelled", " ", "by", " ", "1"}], ",",
        "2", ",", "3", ",", 
       RowBox[{"4", ";", " ", 
        RowBox[{
        "where", " ", "1", " ", "corresponds", " ", "to", " ", "bottom", " ", 
         "left", " ", 
         RowBox[{"(", "i", ")"}]}]}], ",", " ", 
       RowBox[{"2", " ", "to", " ", "bottom", " ", "right", " ", 
        RowBox[{"(", "j", ")"}]}], ",", " ", 
       RowBox[{"3", " ", "to", " ", "top", " ", "left", " ", 
        RowBox[{"(", 
         RowBox[{"i", "'"}], ")"}], " ", "and", " ", "4", " ", "to", " ", 
        "top", " ", "right", " ", 
        RowBox[{"(", 
         RowBox[{"j", "'"}], ")"}]}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "If", " ", "there", " ", "are", " ", "no", " ", "more", " ", 
        "appearances", " ", "of", " ", 
        RowBox[{"braid", "[", 
         RowBox[{"[", "j", "]"}], "]"}]}], ",", " ", 
       RowBox[{
        RowBox[{
        "and", " ", "If", " ", "we", " ", "are", " ", "at", " ", "corner", " ",
          "3", " ", "and", " ", "there", " ", "are", " ", "no", " ", 
         "appearances", " ", "of"}], " ", "+", 
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"braid", "[", 
            RowBox[{"[", "j", "]"}], "]"}], "-", "1"}], ")"}]}]}], ",", " ", 
       RowBox[{
        RowBox[{
        "or", " ", "if", " ", "we", " ", "are", " ", "at", " ", "corner", " ",
          "4", " ", "and", " ", "no", " ", "appearances", " ", "of"}], " ", "+", 
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"braid", "[", 
            RowBox[{"[", "j", "]"}], "]"}], "+", "1"}], ")"}]}]}], ",", 
       RowBox[{
       "then", " ", "we", " ", "are", " ", "at", " ", "the", " ", "top", " ", 
        "strand"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"bool", "=", "True"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
        "If", " ", "there", " ", "are", " ", "more", " ", "appearances", " ", 
         "of", " ", 
         RowBox[{"braid", "[", 
          RowBox[{"[", "j", "]"}], "]"}]}], ",", " ", 
        RowBox[{"we", " ", "turn", " ", "bool", " ", "to", " ", 
         RowBox[{"false", ":"}]}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"bool", "=", 
       RowBox[{
        RowBox[{"Length", "@", 
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"Flatten", "@", 
            RowBox[{"Position", "[", 
             RowBox[{
              RowBox[{"Abs", "@", "braid"}], ",", 
              RowBox[{"Abs", "@", 
               RowBox[{"braid", "[", 
                RowBox[{"[", "j", "]"}], "]"}]}]}], "]"}]}], ",", 
           RowBox[{
            RowBox[{"#", ">", "j"}], "&"}]}], "]"}]}], "==", "0"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", "bool"}], ",", 
        RowBox[{"Return", "[", "False", "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
         RowBox[{
         "If", " ", "we", " ", "are", " ", "at", " ", "corner", " ", "3", " ",
           "and", " ", "there", " ", "are", " ", "appearances", " ", "of"}], 
         " ", "+", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"braid", "[", 
              RowBox[{"[", "j", "]"}], "]"}], "-", "1"}], ")"}]}], " ", 
          "after"}]}], ",", " ", 
        RowBox[{"we", " ", "turn", " ", "bool", " ", "to", " ", 
         RowBox[{"False", ":"}]}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"corner", "==", "3"}], "&&", 
         RowBox[{
          RowBox[{"Abs", "@", 
           RowBox[{"braid", "[", 
            RowBox[{"[", "j", "]"}], "]"}]}], ">", "1"}]}], ",", 
        RowBox[{"bool", "=", 
         RowBox[{
          RowBox[{"Length", "@", 
           RowBox[{"Select", "[", 
            RowBox[{
             RowBox[{"Flatten", "@", 
              RowBox[{"Position", "[", 
               RowBox[{
                RowBox[{"Abs", "@", "braid"}], ",", 
                RowBox[{
                 RowBox[{"Abs", "@", 
                  RowBox[{"braid", "[", 
                   RowBox[{"[", "j", "]"}], "]"}]}], "-", "1"}]}], "]"}]}], ",", 
             RowBox[{
              RowBox[{"#", ">", "j"}], "&"}]}], "]"}]}], "==", "0"}]}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", "bool"}], ",", 
        RowBox[{"Return", "[", "False", "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
         RowBox[{
         "If", " ", "we", " ", "are", " ", "at", " ", "corner", " ", "4", " ",
           "and", " ", "there", " ", "are", " ", "appearances", " ", "of"}], 
         " ", "+", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"braid", "[", 
              RowBox[{"[", "j", "]"}], "]"}], "+", "1"}], ")"}]}], " ", 
          "after"}]}], ",", " ", 
        RowBox[{"we", " ", "turn", " ", "bool", " ", "to", " ", 
         RowBox[{"False", ":"}]}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"corner", "==", "4"}], "&&", 
         RowBox[{
          RowBox[{"Abs", "@", 
           RowBox[{"braid", "[", 
            RowBox[{"[", "j", "]"}], "]"}]}], "<", 
          RowBox[{"Max", "@", 
           RowBox[{"Abs", "@", "braid"}]}]}]}], ",", 
        RowBox[{"bool", "=", 
         RowBox[{
          RowBox[{"Length", "@", 
           RowBox[{"Select", "[", 
            RowBox[{
             RowBox[{"Flatten", "@", 
              RowBox[{"Position", "[", 
               RowBox[{
                RowBox[{"Abs", "@", "braid"}], ",", 
                RowBox[{
                 RowBox[{"Abs", "@", 
                  RowBox[{"braid", "[", 
                   RowBox[{"[", "j", "]"}], "]"}]}], "+", "1"}]}], "]"}]}], ",", 
             RowBox[{
              RowBox[{"#", ">", "j"}], "&"}]}], "]"}]}], "==", "0"}]}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", "bool"}], ",", 
        RowBox[{"Return", "[", "False", "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", "bool"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"firstAppearance", "[", 
    RowBox[{"braid_", ",", "gen_"}], "]"}], ":=", 
   RowBox[{"First", "@", 
